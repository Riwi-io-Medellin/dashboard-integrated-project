<!DOCTYPE html>
<html lang="es" class="h-full">
  <head>
    <title><%= content_for(:title) || "Registro de Equipo — RIWI" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Registra tu equipo para el Proyecto Integrado RIWI">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    </style>
  </head>
  <body class="min-h-full bg-gray-950 text-gray-100">
    <div class="min-h-screen flex flex-col">
      <!-- Header -->
      <header class="bg-gray-900/80 backdrop-blur-sm border-b border-gray-800 sticky top-0 z-30">
        <div class="max-w-2xl mx-auto px-4 h-14 flex items-center gap-3">
          <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-violet-500 to-fuchsia-500 flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <span class="text-base font-bold bg-gradient-to-r from-violet-400 to-fuchsia-400 bg-clip-text text-transparent">RIWI — Proyecto Integrado</span>
        </div>
      </header>

      <!-- Flash Messages -->
      <% if notice %>
        <div class="max-w-2xl mx-auto px-4 mt-4">
          <div class="p-4 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <%= notice %>
          </div>
        </div>
      <% end %>

      <% if alert %>
        <div class="max-w-2xl mx-auto px-4 mt-4">
          <div class="p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-sm flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <%= alert %>
          </div>
        </div>
      <% end %>

      <!-- Content -->
      <main class="flex-1 max-w-2xl mx-auto w-full px-4 py-6">
        <%= yield %>
      </main>

      <!-- Footer -->
      <footer class="py-6 text-center text-xs text-gray-600 border-t border-gray-800/50">
        <p>&copy; <%= Date.current.year %> RIWI — Proyectos Integrados</p>
      </footer>
    </div>
  </body>
</html>
