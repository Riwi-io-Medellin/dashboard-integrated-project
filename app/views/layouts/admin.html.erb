<!DOCTYPE html>
<html lang="es" class="h-full">
  <head>
    <title><%= content_for(:title) || "RIWI — Proyectos integradores" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Dashboard de Proyectos integradores RIWI">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    </style>
  </head>
  <body class="h-full bg-gray-950 text-gray-100">
    <div class="min-h-full flex">
      <!-- Sidebar -->
      <aside id="sidebar" class="hidden lg:flex lg:flex-col lg:w-72 bg-gray-900 border-r border-gray-800 fixed inset-y-0 left-0 z-40">
        <!-- Logo -->
        <div class="flex items-center h-16 px-6 border-b border-gray-800">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-violet-500 to-fuchsia-500 flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <span class="text-lg font-bold bg-gradient-to-r from-violet-400 to-fuchsia-400 bg-clip-text text-transparent">RIWI</span>
          </div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
          <p class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Principal</p>

          <%= link_to admin_dashboard_path, class: "group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 #{request.path == admin_dashboard_path ? 'bg-violet-500/10 text-violet-400 shadow-sm' : 'text-gray-400 hover:text-gray-200 hover:bg-gray-800/50'}" do %>
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            Dashboard
          <% end %>

          <%= link_to admin_groups_path, class: "group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 #{controller.controller_path == 'admin/groups' ? 'bg-violet-500/10 text-violet-400 shadow-sm' : 'text-gray-400 hover:text-gray-200 hover:bg-gray-800/50'}" do %>
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
            Grupos
          <% end %>

          <%= link_to admin_coders_path, class: "group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 #{controller.controller_path == 'admin/coders' ? 'bg-violet-500/10 text-violet-400 shadow-sm' : 'text-gray-400 hover:text-gray-200 hover:bg-gray-800/50'}" do %>
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            Coders
          <% end %>

          <%= link_to admin_teams_path, class: "group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 #{controller.controller_path == 'admin/teams' ? 'bg-violet-500/10 text-violet-400 shadow-sm' : 'text-gray-400 hover:text-gray-200 hover:bg-gray-800/50'}" do %>
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            Equipos
          <% end %>
        </nav>

        <!-- User info -->
        <div class="px-4 py-4 border-t border-gray-800">
          <div class="flex items-center gap-3 px-3 py-2">
            <div class="w-9 h-9 rounded-full bg-gradient-to-br from-violet-500 to-fuchsia-500 flex items-center justify-center text-sm font-bold text-white">
              <%= current_user.email[0].upcase %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-200 truncate"><%= current_user.email %></p>
              <p class="text-xs text-gray-500 capitalize"><%= current_user.role.gsub('_', ' ') %></p>
            </div>
          </div>
          <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "flex items-center gap-2 px-3 py-2 mt-1 text-sm text-gray-500 hover:text-red-400 transition-colors rounded-lg hover:bg-gray-800/50" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            Cerrar Sesión
          <% end %>
        </div>
      </aside>

      <!-- Mobile header -->
      <div class="lg:hidden fixed top-0 inset-x-0 z-40 bg-gray-900/95 backdrop-blur-sm border-b border-gray-800">
        <div class="flex items-center justify-between h-14 px-4">
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-violet-500 to-fuchsia-500 flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <span class="text-base font-bold bg-gradient-to-r from-violet-400 to-fuchsia-400 bg-clip-text text-transparent">RIWI</span>
          </div>
          <button id="mobile-menu-btn" class="p-2 text-gray-400 hover:text-gray-200">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu overlay -->
      <div id="mobile-menu" class="hidden fixed inset-0 z-50 lg:hidden">
        <div class="absolute inset-0 bg-black/60" id="mobile-menu-overlay"></div>
        <div class="absolute inset-y-0 left-0 w-72 bg-gray-900 shadow-2xl p-4 space-y-2">
          <div class="flex items-center justify-between mb-6">
            <span class="text-lg font-bold bg-gradient-to-r from-violet-400 to-fuchsia-400 bg-clip-text text-transparent">RIWI</span>
            <button id="close-menu-btn" class="p-2 text-gray-400 hover:text-gray-200">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <%= link_to "Dashboard", admin_dashboard_path, class: "block px-4 py-3 rounded-xl text-sm font-medium text-gray-300 hover:bg-gray-800" %>
          <%= link_to "Grupos", admin_groups_path, class: "block px-4 py-3 rounded-xl text-sm font-medium text-gray-300 hover:bg-gray-800" %>
          <%= link_to "Coders", admin_coders_path, class: "block px-4 py-3 rounded-xl text-sm font-medium text-gray-300 hover:bg-gray-800" %>
          <%= link_to "Equipos", admin_teams_path, class: "block px-4 py-3 rounded-xl text-sm font-medium text-gray-300 hover:bg-gray-800" %>
          <div class="pt-4 border-t border-gray-800">
            <%= link_to "Cerrar Sesión", destroy_user_session_path, data: { turbo_method: :delete }, class: "block px-4 py-3 rounded-xl text-sm text-red-400 hover:bg-gray-800" %>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <main class="flex-1 lg:ml-72 pt-14 lg:pt-0">
        <!-- Flash Messages -->
        <% if notice %>
          <div class="mx-4 mt-4 lg:mx-8 lg:mt-6 p-4 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <%= notice %>
          </div>
        <% end %>

        <% if alert %>
          <div class="mx-4 mt-4 lg:mx-8 lg:mt-6 p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-sm flex items-center gap-3">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <%= alert %>
          </div>
        <% end %>

        <% if flash[:import_errors]&.any? %>
          <div class="mx-4 mt-2 lg:mx-8 p-4 rounded-xl bg-amber-500/10 border border-amber-500/20 text-amber-400 text-sm">
            <p class="font-medium mb-2">Errores de importación:</p>
            <ul class="list-disc list-inside space-y-1 text-xs">
              <% flash[:import_errors].each do |error| %>
                <li><%= error %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="p-4 lg:p-8">
          <%= yield %>
        </div>
      </main>
    </div>

    <script>
      // Mobile menu toggle
      document.addEventListener('DOMContentLoaded', function() {
        const menuBtn = document.getElementById('mobile-menu-btn');
        const closeBtn = document.getElementById('close-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const overlay = document.getElementById('mobile-menu-overlay');

        if (menuBtn) {
          menuBtn.addEventListener('click', () => mobileMenu.classList.remove('hidden'));
        }
        if (closeBtn) {
          closeBtn.addEventListener('click', () => mobileMenu.classList.add('hidden'));
        }
        if (overlay) {
          overlay.addEventListener('click', () => mobileMenu.classList.add('hidden'));
        }
      });
    </script>
  </body>
</html>
