<% content_for(:title, "Mi Dashboard — RIWI") %>

<div class="max-w-4xl mx-auto py-10">
  <div class="bg-gray-900 rounded-2xl border border-gray-800 p-8 shadow-2xl text-center">
    <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-violet-500 to-fuchsia-500 flex items-center justify-center mx-auto mb-6 shadow-xl shadow-violet-500/30">
      <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>

    <h1 class="text-3xl font-bold text-white mb-2">¡Hola, <%= current_user.email %>!</h1>
    <p class="text-gray-400 mb-8">Has iniciado sesión correctamente como <span class="text-violet-400 font-medium"><%= current_user.role.humanize %></span>.</p>

    <div class="bg-gray-800/50 rounded-xl p-6 border border-gray-700/50 max-w-lg mx-auto mb-8">
      <h3 class="text-lg font-medium text-white mb-2">Estado de Registro</h3>
      <% if current_user.coder %>
        <div class="flex items-center justify-center gap-2 text-emerald-400">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span>Vinculado al coder: <%= current_user.coder.full_name %></span>
        </div>
      <% else %>
        <div class="flex items-center justify-center gap-2 text-amber-400">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <span>No estás vinculado a ningún perfil de coder</span>
        </div>
      <% end %>
    </div>

    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "inline-flex items-center gap-2 px-6 py-3 bg-gray-800 hover:bg-gray-700 text-gray-300 font-medium rounded-xl transition-all border border-gray-700" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      Cerrar Sesión
    <% end %>
  </div>
</div>
