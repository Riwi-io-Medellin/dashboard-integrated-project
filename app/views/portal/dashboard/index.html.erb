<% content_for(:title, "Mi Portal — RIWI") %>

<!-- Welcome Header -->
<div class="mb-8">
  <h1 class="text-3xl font-bold text-white">Mi Portal</h1>
  <p class="text-gray-400 mt-1">Bienvenido, <span class="text-violet-400 font-medium"><%= current_user.email %></span></p>
</div>

<% if @team&.github_repo_url.present? %>
  <!-- GitHub Repo Alert -->
  <div class="mb-8 p-0.5 rounded-2xl bg-gradient-to-r from-violet-600 via-fuchsia-500 to-indigo-600 shadow-xl shadow-violet-500/20 animate-pulse-slow">
    <div class="bg-gray-900 rounded-[14px] p-4 sm:p-6 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-5 text-center sm:text-left">
        <div class="w-14 h-14 rounded-2xl bg-violet-500/10 flex items-center justify-center flex-shrink-0 border border-violet-500/20">
          <svg class="w-8 h-8 text-violet-400" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-white mb-1">¡Tu repositorio está listo!</h3>
          <p class="text-gray-400 text-sm max-w-md">Ya puedes empezar a trabajar en el repositorio de GitHub de RIWI ha sido configurado para tu equipo.</p>
        </div>
      </div>
      <%= link_to @team.github_repo_url, target: "_blank", class: "w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 bg-white hover:bg-violet-50 text-gray-900 font-bold rounded-xl transition-all duration-300 transform hover:scale-105 shadow-lg group shadow-white/10" do %>
        Ir al Repositorio
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      <% end %>
    </div>
  </div>

  <style>
    @keyframes pulse-slow {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.95; transform: scale(0.995); }
    }
    .animate-pulse-slow {
      animation: pulse-slow 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
  </style>
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Team Status Card -->
  <div class="bg-gray-900 rounded-2xl border border-gray-800 p-6 shadow-xl">
    <div class="flex items-center gap-3 mb-5">
      <div class="w-10 h-10 rounded-xl bg-violet-500/10 flex items-center justify-center">
        <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-white">Mi Equipo</h2>
    </div>

    <% if @team %>
      <!-- Team info rows -->
      <div class="space-y-3 mb-4">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Nombre</span>
          <span class="text-sm font-semibold text-white"><%= @team.name %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Categoría</span>
          <span class="px-3 py-1 text-xs font-medium rounded-full bg-violet-500/10 text-violet-300 border border-violet-500/20"><%= @team.category_label %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Clan</span>
          <span class="text-sm font-medium text-white"><%= @team.group&.name || "—" %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">API de OpenAI</span>
          <% if @team.needs_openai_api? %>
            <span class="px-2 py-1 text-xs font-medium rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">✓ Sí</span>
          <% else %>
            <span class="px-2 py-1 text-xs font-medium rounded-full bg-gray-700 text-gray-500 border border-gray-700">No</span>
          <% end %>
        </div>
      </div>

      <!-- Members -->
      <div class="border-t border-gray-800 pt-4">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Miembros (<%= @team_members.size %>)</p>
        <div class="space-y-2">
          <% @team_members.each do |tm| %>
            <% is_leader = tm.role == "leader" %>
            <div class="flex items-center gap-3 p-2.5 rounded-xl <%= is_leader ? 'bg-amber-500/5 border border-amber-500/20' : 'bg-gray-800/40 border border-gray-700/30' %>">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 <%= is_leader ? 'bg-amber-400/20 text-amber-300' : 'bg-violet-500/15 text-violet-300' %>">
                <%= tm.coder.full_name.split(' ').map { |n| n[0] }.first(2).join.upcase %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium truncate <%= is_leader ? 'text-amber-200' : 'text-gray-200' %>"><%= tm.coder.full_name %></p>
                <p class="text-xs text-gray-500"><%= tm.coder.group&.name || "Sin clan" %></p>
              </div>
              <% if is_leader %>
                <span class="text-xs px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-400 flex-shrink-0">★ Líder</span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="pt-4 border-t border-gray-800 mt-4">
        <%= link_to portal_team_path(@team), class: "inline-flex items-center gap-2 text-sm text-violet-400 hover:text-violet-300 font-medium transition-colors" do %>
          Ver detalles completos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      </div>
    <% else %>
      <!-- No team -->
      <div class="text-center py-6">
        <div class="w-16 h-16 rounded-full bg-gray-800 flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
          </svg>
        </div>
        <p class="text-gray-400 text-sm mb-1">Aún no perteneces a un equipo</p>
        <p class="text-gray-600 text-xs mb-5">Crea un equipo y agrega a tus compañeros</p>
        <%= link_to new_portal_team_path, class: "inline-flex items-center gap-2 px-5 py-2.5 text-white font-semibold rounded-xl transition-all duration-200 text-sm", style: "background: linear-gradient(135deg, #7C3AED, #6D28D9); box-shadow: 0 4px 20px rgba(124,58,237,0.3);" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Crear Equipo
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @coder %>
    <!-- Profile Card -->
    <div class="bg-gray-900 rounded-2xl border border-gray-800 p-6 shadow-xl mb-6">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-violet-500/20 to-fuchsia-500/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-white">Mi Perfil</h2>
      </div>

      <!-- Avatar + Name -->
      <div class="flex items-center gap-4 mb-5 p-4 rounded-xl bg-gradient-to-br from-violet-500/5 to-fuchsia-500/5 border border-violet-500/10">
        <div class="w-14 h-14 rounded-full bg-gradient-to-br from-violet-500/30 to-fuchsia-500/30 flex items-center justify-center text-lg font-bold text-violet-300 flex-shrink-0">
          <%= @coder.first_name[0] %><%= @coder.last_name[0] %>
        </div>
        <div>
          <p class="text-base font-semibold text-white"><%= @coder.full_name %></p>
          <% if @coder.group %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-violet-500/10 text-violet-400 mt-1"><%= @coder.group.name %></span>
          <% end %>
        </div>
      </div>

      <!-- Info Grid -->
      <div class="space-y-3">
        <!-- Email -->
        <div class="flex items-center gap-3 p-2.5 rounded-lg bg-gray-800/30">
          <svg class="w-4 h-4 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <div class="min-w-0 flex-1">
            <p class="text-xs text-gray-500">Email</p>
            <p class="text-sm text-gray-200 truncate"><%= @coder.email.presence || "—" %></p>
          </div>
        </div>

        <!-- Phone -->
        <% if @coder.phone.present? %>
          <div class="flex items-center gap-3 p-2.5 rounded-lg bg-gray-800/30">
            <svg class="w-4 h-4 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <div class="min-w-0 flex-1">
              <p class="text-xs text-gray-500">Teléfono</p>
              <p class="text-sm text-gray-200"><%= @coder.phone %></p>
            </div>
          </div>
        <% end %>

        <!-- Document -->
        <% if @coder.national_id.present? %>
          <div class="flex items-center gap-3 p-2.5 rounded-lg bg-gray-800/30">
            <svg class="w-4 h-4 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/></svg>
            <div class="min-w-0 flex-1">
              <p class="text-xs text-gray-500">Documento</p>
              <p class="text-sm text-gray-200"><%= @coder.national_id %></p>
            </div>
          </div>
        <% end %>

        <!-- Student ID -->
        <% if @coder.student_id.present? %>
          <div class="flex items-center gap-3 p-2.5 rounded-lg bg-gray-800/30">
            <svg class="w-4 h-4 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/></svg>
            <div class="min-w-0 flex-1">
              <p class="text-xs text-gray-500">ID Estudiante</p>
              <p class="text-sm text-gray-200"><%= @coder.student_id %></p>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Social Links -->
      <% if @coder.github_user.present? || @coder.discord_user.present? %>
        <div class="mt-4 pt-4 border-t border-gray-800">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Redes</p>
          <div class="space-y-2">
            <% if @coder.github_user.present? %>
              <a href="https://github.com/<%= @coder.github_user %>" target="_blank" class="flex items-center gap-3 p-2.5 rounded-lg bg-gray-800/30 hover:bg-gray-800/60 transition-colors group">
                <svg class="w-4 h-4 text-gray-500 group-hover:text-violet-400 flex-shrink-0 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
                <div class="min-w-0 flex-1">
                  <p class="text-xs text-gray-500">GitHub</p>
                  <p class="text-sm text-violet-400 group-hover:text-violet-300 truncate"><%= @coder.github_user %></p>
                </div>
                <svg class="w-4 h-4 text-gray-600 group-hover:text-violet-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            <% end %>
            <% if @coder.discord_user.present? %>
              <div class="flex items-center gap-3 p-2.5 rounded-lg bg-gray-800/30">
                <svg class="w-4 h-4 text-gray-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
                <div class="min-w-0 flex-1">
                  <p class="text-xs text-gray-500">Discord</p>
                  <p class="text-sm text-indigo-400 truncate"><%= @coder.discord_user %></p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  <% end %>

  <!-- Resources Card -->
  <div class="bg-gray-900 rounded-2xl border border-gray-800 p-6 shadow-xl">
    <div class="flex items-center gap-3 mb-5">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500/20 to-teal-500/20 flex items-center justify-center">
        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-white">Recursos</h2>
    </div>

    <div class="space-y-3">
      <!-- PDF Download -->
      <a href="/Enunciado-Proyecto-Integrador-Ruta-Base.pdf" target="_blank" class="flex items-center gap-3 p-3 rounded-xl bg-gradient-to-r from-red-500/5 to-orange-500/5 border border-red-500/10 hover:border-red-500/30 transition-all group">
        <div class="w-10 h-10 rounded-lg bg-red-500/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-gray-200 group-hover:text-white transition-colors">Enunciado del Proyecto Integrador</p>
          <p class="text-xs text-gray-500">PDF · Reglas y lineamientos</p>
        </div>
        <svg class="w-4 h-4 text-gray-600 group-hover:text-red-400 transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
      </a>

      <!-- Quick Links -->
      <% if @team&.github_repo_url.present? %>
        <a href="<%= @team.github_repo_url %>" target="_blank" class="flex items-center gap-3 p-3 rounded-xl bg-gray-800/30 hover:bg-gray-800/60 transition-all group">
          <div class="w-10 h-10 rounded-lg bg-gray-800 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-gray-400 group-hover:text-violet-400 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-200 group-hover:text-white transition-colors">Repositorio del Equipo</p>
            <p class="text-xs text-gray-500 truncate"><%= @team.github_repo_url.gsub("https://github.com/", "") %></p>
          </div>
          <svg class="w-4 h-4 text-gray-600 group-hover:text-violet-400 transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      <% end %>
    </div>
  </div>

</div>
