<% content_for(:title, "#{@team.name} — RIWI") %>

<div class="max-w-2xl mx-auto">
  <!-- Nav row -->
  <div class="mb-6 flex items-center justify-between">
    <%= link_to portal_dashboard_path, class: "inline-flex items-center gap-2 text-sm text-gray-400 hover:text-gray-200 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Volver al Dashboard
    <% end %>
    <% can_edit = @team.created_by_user_id == current_user.id || current_user.coder&.team_id == @team.id %>
    <% if can_edit %>
      <%= link_to edit_portal_team_path(@team), class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white rounded-xl border border-gray-700 transition-all" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Editar Equipo
      <% end %>
    <% end %>
  </div>

  <!-- Team Header -->
  <div class="bg-gray-900 rounded-2xl border border-gray-800 p-6 shadow-xl mb-6">
    <div class="flex items-center gap-4 mb-5">
        <div class="w-14 h-14 rounded-2xl flex items-center justify-center shadow-xl" style="background: linear-gradient(135deg, #7C3AED, #4F46E5); box-shadow: 0 8px 32px rgba(124,58,237,0.3);">
        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
      </div>
      <div class="flex-1">
        <h1 class="text-2xl font-bold text-white"><%= @team.name %></h1>
        <div class="flex items-center gap-3 mt-1">
          <span class="px-3 py-1 text-xs font-medium rounded-full bg-violet-500/10 text-violet-300 border border-violet-500/20"><%= @team.category_label %></span>
          <span class="text-xs text-gray-500">Clan: <span class="text-gray-300"><%= @team.group&.name || "—" %></span></span>
        </div>
      </div>
    </div>

    <!-- Details -->
    <div class="grid grid-cols-2 gap-3">
      <div class="p-3 rounded-xl bg-gray-800/50 border border-gray-700/30">
        <p class="text-xs text-gray-500 mb-1">Miembros</p>
        <p class="text-lg font-bold text-white"><%= @members.size %></p>
      </div>
      <div class="p-3 rounded-xl bg-gray-800/50 border border-gray-700/30">
        <p class="text-xs text-gray-500 mb-1">API de OpenAI</p>
        <% if @team.needs_openai_api? %>
          <span class="text-sm font-semibold text-emerald-400">✓ Sí</span>
        <% else %>
          <span class="text-sm font-semibold text-gray-500">No</span>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Members List -->
  <div class="bg-gray-900 rounded-2xl border border-gray-800 p-6 shadow-xl">
    <h2 class="text-lg font-semibold text-white mb-4">Miembros (<%= @members.size %>)</h2>

    <div class="space-y-3">
      <% @members.each do |tm| %>
        <% coder = tm.coder %>
        <% is_leader = tm.role == "leader" %>
        <div class="flex items-center gap-3 p-3 rounded-xl border transition-all <%= is_leader ? 'bg-amber-500/5 border-amber-500/30' : 'bg-gray-800/30 border-gray-700/50' %>">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0 <%= is_leader ? 'bg-amber-400/20 text-amber-300' : 'bg-violet-500/15 text-violet-300' %>">
            <%= coder.full_name.split(' ').map { |n| n[0] }.first(2).join.upcase %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <p class="text-sm font-medium truncate <%= is_leader ? 'text-amber-200' : 'text-gray-200' %>"><%= coder.full_name %></p>
              <% if is_leader %>
                <span class="text-xs px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-400 font-medium flex-shrink-0">★ Líder</span>
              <% end %>
            </div>
            <p class="text-xs text-gray-500 truncate">
              Clan: <%= coder.group&.name || "Sin clan" %>
              <% if coder.email.present? %> • <%= coder.email %><% end %>
              <% if coder.national_id.present? %> • Doc: <%= coder.national_id %><% end %>
            </p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
