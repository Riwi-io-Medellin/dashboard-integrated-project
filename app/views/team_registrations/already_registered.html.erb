<% content_for(:title, "Equipo Ya Registrado") %>

<div class="text-center py-12">
  <div class="w-16 h-16 rounded-full bg-amber-500/10 flex items-center justify-center mx-auto mb-6">
    <svg class="w-8 h-8 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
  </div>
  <h1 class="text-2xl font-bold text-white mb-3">Equipo Ya Registrado</h1>
  <p class="text-gray-400 text-sm mb-2">
    El equipo <span class="text-violet-400 font-medium"><%= @team.name %></span>
    ya fue registrado el <%= @team.registered_at&.strftime("%d/%m/%Y a las %H:%M") %>.
  </p>

  <% if @team.coders.any? %>
    <div class="mt-8 bg-gray-900 rounded-2xl border border-gray-800 p-6 max-w-sm mx-auto">
      <h2 class="text-sm font-semibold text-gray-300 mb-4">Miembros del Equipo</h2>
      <div class="space-y-2">
        <% @team.team_members.includes(:coder).each do |member| %>
          <div class="flex items-center gap-3 text-left">
            <div class="w-7 h-7 rounded-full bg-gradient-to-br from-violet-500/20 to-fuchsia-500/20 flex items-center justify-center text-xs font-bold text-violet-300">
              <%= member.coder.first_name[0] %>
            </div>
            <span class="text-sm text-gray-300 flex-1"><%= member.coder.full_name %></span>
            <% if member.role == "leader" %>
              <span class="text-xs text-amber-400">★ Líder</span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
