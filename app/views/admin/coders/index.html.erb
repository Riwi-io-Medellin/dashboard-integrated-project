<% content_for(:title, "Coders — RIWI") %>

<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
  <div>
    <h1 class="text-2xl lg:text-3xl font-bold text-white">Coders</h1>
    <p class="text-gray-500 mt-1">Gestiona los estudiantes registrados</p>
  </div>

  <div class="flex items-center gap-3">
    <!-- Download CSV -->
    <%= link_to export_admin_coders_path, class: "inline-flex items-center gap-2 px-4 py-2.5 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-500 hover:to-teal-500 text-white text-sm font-medium rounded-xl transition-all duration-200 shadow-lg shadow-emerald-500/25" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
      </svg>
      Descargar Excel
    <% end %>

    <!-- Import Excel -->
    <%= form_with url: import_admin_coders_path, method: :post, multipart: true, class: "flex items-center gap-2" do %>
      <label class="cursor-pointer inline-flex items-center gap-2 px-4 py-2.5 bg-gray-800 border border-gray-700 hover:border-emerald-500/50 text-gray-300 text-sm font-medium rounded-xl transition-all duration-200">
        <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
        </svg>
        <span id="file-label">Importar Excel</span>
        <input type="file" name="file" accept=".xlsx,.xls" class="hidden" onchange="document.getElementById('file-label').textContent = this.files[0]?.name || 'Importar Excel'; document.getElementById('import-btn').classList.remove('hidden');">
      </label>
      <button type="submit" id="import-btn" class="hidden px-4 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-xl transition-all duration-200">
        Subir
      </button>
    <% end %>
  </div>
</div>

<!-- Filters -->
<div class="flex flex-col sm:flex-row gap-3 mb-6">
  <%= form_with url: admin_coders_path, method: :get, class: "flex flex-col sm:flex-row gap-3 flex-1" do %>
    <input type="text" name="search" value="<%= params[:search] %>" placeholder="Buscar por nombre, email o ID..." class="flex-1 px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-xl text-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500 transition-all placeholder-gray-600">
    <select name="group_id" class="px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-xl text-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500 transition-all" onchange="this.form.requestSubmit()">
      <option value="">Todos los grupos</option>
      <% @groups.each do |group| %>
        <option value="<%= group.id %>" <%= 'selected' if params[:group_id].to_s == group.id.to_s %>><%= group.name %></option>
      <% end %>
    </select>
    <button type="submit" class="px-4 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-xl transition-colors">Buscar</button>
  <% end %>
</div>

<!-- Coders Table -->
<div class="bg-gray-900 rounded-2xl border border-gray-800 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-gray-800">
          <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Nombre</th>
          <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
          <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Grupo</th>
          <th class="text-center px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">ID Est.</th>
          <th class="text-center px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Estado</th>
          <th class="text-right px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Acciones</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-800/50">
        <% @coders.each do |coder| %>
          <tr class="hover:bg-gray-800/30 transition-colors">
            <td class="px-6 py-3">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet-500/30 to-fuchsia-500/30 flex items-center justify-center text-xs font-bold text-violet-300">
                  <%= coder.first_name[0] %><%= coder.last_name[0] %>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-200"><%= coder.full_name %></p>
                  <p class="text-xs text-gray-500"><%= coder.phone %></p>
                </div>
              </div>
            </td>
            <td class="px-6 py-3 text-sm text-gray-400"><%= coder.email %></td>
            <td class="px-6 py-3">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-violet-500/10 text-violet-400"><%= coder.group.name %></span>
            </td>
            <td class="px-6 py-3 text-sm text-gray-400 text-center"><%= coder.student_id %></td>
            <td class="px-6 py-3 text-center">
              <% if coder.team_member %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400">
                  <%= coder.team.name rescue 'Asignado' %>
                </span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-700 text-gray-400">Disponible</span>
              <% end %>
            </td>
            <td class="px-6 py-3 text-right">
              <%= link_to admin_coder_path(coder), data: { turbo_method: :delete, turbo_confirm: "¿Estás seguro de eliminar a #{coder.full_name}?" }, class: "inline-flex items-center p-2 text-gray-500 hover:text-red-400 transition-colors rounded-lg hover:bg-red-500/10", title: "Eliminar Coder" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @coders.empty? %>
    <div class="text-center py-12 text-gray-500">
      <svg class="w-12 h-12 mx-auto mb-4 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
      </svg>
      <p class="text-sm">No se encontraron coders.</p>
      <p class="text-xs text-gray-600 mt-1">Importa un archivo Excel para empezar.</p>
    </div>
  <% end %>
</div>
