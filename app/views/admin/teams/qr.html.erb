<% content_for(:title, "QR — #{@team.name}") %>

<div class="max-w-lg mx-auto text-center">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white"><%= @team.name %></h1>
    <p class="text-gray-500 mt-1"><%= @team.group.name %> · <%= @team.category_label %></p>
  </div>

  <div class="bg-gray-900 rounded-2xl border border-gray-800 p-8 mb-6">
    <div class="bg-white rounded-xl p-6 inline-block mb-6">
      <%= raw @qr_svg %>
    </div>
    <p class="text-sm text-gray-400 mb-2">Escanea este código QR para registrar tu equipo</p>
    <p class="text-xs text-gray-600 break-all px-4"><%= team_registration_url(token: @team.token) %></p>
  </div>

  <div class="flex items-center justify-center gap-3">
    <%= link_to admin_team_path(@team), class: "px-6 py-3 text-sm text-gray-400 hover:text-gray-200 transition-colors" do %>
      ← Volver al equipo
    <% end %>
  </div>
</div>
