<% content_for(:title, "#{@team.name} — RIWI") %>

<div class="mb-8">
  <div class="flex items-center gap-3 mb-2">
    <%= link_to admin_teams_path, class: "text-gray-500 hover:text-gray-300 transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="text-2xl lg:text-3xl font-bold text-white"><%= @team.name %></h1>
    <span class="text-xs px-2.5 py-1 rounded-full <%= @team.registered_at ? 'bg-emerald-500/10 text-emerald-400' : 'bg-amber-500/10 text-amber-400' %>">
      <%= @team.registered_at ? 'Registrado' : 'Pendiente' %>
    </span>
    <div class="ml-auto">
      <%= button_to admin_team_path(@team), method: :delete, data: { confirm: "¿Estás seguro de eliminar este equipo? Esta acción no se puede deshacer." }, class: "inline-flex items-center gap-2 px-3 py-1.5 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-xs font-medium rounded-lg border border-red-500/20 transition-all" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Eliminar Proyecto
      <% end %>
    </div>
  </div>
  <p class="text-gray-500"><%= @team.group.name %> · <%= @team.category_label %></p>
</div>

<!-- Team Info -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <div class="lg:col-span-2 bg-gray-900 rounded-2xl border border-gray-800 p-6">
    <h2 class="text-lg font-semibold text-white mb-4">Miembros del Equipo</h2>
    <% if @team.team_members.any? %>
      <div class="space-y-3">
        <% @team.team_members.includes(:coder).each do |member| %>
          <div class="flex items-center gap-4 p-3 rounded-xl bg-gray-800/30">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br <%= member.role == 'leader' ? 'from-amber-400/30 to-orange-400/30' : 'from-violet-500/30 to-fuchsia-500/30' %> flex items-center justify-center text-sm font-bold <%= member.role == 'leader' ? 'text-amber-300' : 'text-violet-300' %>">
              <%= member.coder.first_name[0] %><%= member.coder.last_name[0] %>
            </div>
            <div class="flex-1">
              <p class="text-sm font-medium text-gray-200"><%= member.coder.full_name %></p>
              <div class="flex items-center gap-3 mt-0.5">
                <p class="text-xs text-gray-500 flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  <%= member.coder.email %>
                </p>
                <% if member.coder.github_user.present? %>
                  <a href="https://github.com/<%= member.coder.github_user %>" target="_blank" class="text-xs text-violet-400 hover:text-violet-300 flex items-center gap-1 transition-colors" title="Ver perfil en GitHub">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
                    <%= member.coder.github_user %>
                  </a>
                <% else %>
                  <p class="text-xs text-gray-600 flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
                    Sin GitHub
                  </p>
                <% end %>
              </div>
            </div>
            <span class="text-xs px-2.5 py-1 rounded-full <%= member.role == 'leader' ? 'bg-amber-500/10 text-amber-400' : 'bg-gray-700 text-gray-400' %>">
              <%= member.role == 'leader' ? 'Líder' : 'Miembro' %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-sm py-4 text-center">No hay miembros registrados. Comparte el código QR para que el equipo se registre.</p>
    <% end %>
  </div>

  <!-- QR Code & Actions -->
  <div class="space-y-6">
    <div class="bg-gray-900 rounded-2xl border border-gray-800 p-6 text-center">
      <h2 class="text-lg font-semibold text-white mb-4">Código QR</h2>
      <div class="bg-white rounded-xl p-4 inline-block mb-4">
        <%= raw QrGeneratorService.new(team_registration_url(token: @team.token)).to_svg %>
      </div>
      <p class="text-xs text-gray-500 mb-4 break-all"><%= team_registration_url(token: @team.token) %></p>
      <%= link_to qr_admin_team_path(@team), class: "inline-flex items-center gap-2 px-4 py-2.5 bg-gray-800 border border-gray-700 hover:border-violet-500/30 text-gray-300 text-sm font-medium rounded-xl transition-all" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Ver QR Completo
      <% end %>
    </div>

    <!-- GitHub Integration -->
    <div class="bg-gray-900 rounded-2xl border border-gray-800 p-6 text-center">
      <h2 class="text-lg font-semibold text-white mb-4">Integra tu Equipo</h2>
      <% if @team.github_repo_url.present? %>
        <div class="p-4 rounded-xl bg-gray-800/30">
          <p class="text-sm text-gray-400 mb-2">Repositorio Asociado</p>
          <%= link_to @team.github_repo_url, target: "_blank", class: "inline-flex items-center gap-2 text-violet-400 hover:text-violet-300 transition-colors" do %>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
            <span class="break-all font-medium">Ver en GitHub</span>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500 mb-4">Centraliza el código creando el repositorio de este proyecto de RIWI.</p>
        <%= button_to create_github_repo_admin_team_path(@team), method: :post, class: "inline-flex items-center gap-2 px-4 py-2 bg-gray-100 hover:bg-white text-gray-900 text-sm font-semibold rounded-xl transition-all w-full justify-center" do %>
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
          Crear Repo en GitHub
        <% end %>
      <% end %>
    </div>
  </div>
</div>
