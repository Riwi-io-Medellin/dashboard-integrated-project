<% content_for(:title, "#{@group.name} — RIWI") %>

<div class="mb-8">
  <div class="flex items-center gap-3 mb-2">
    <%= link_to admin_groups_path, class: "text-gray-500 hover:text-gray-300 transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="text-2xl lg:text-3xl font-bold text-white"><%= @group.name %></h1>
    <% if @group.jornada.present? %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium <%= @group.jornada == 'AM' ? 'bg-amber-500/10 text-amber-400' : 'bg-indigo-500/10 text-indigo-400' %>">
        <%= @group.jornada == 'AM' ? '☀️ AM' : '🌙 PM' %>
      </span>
    <% end %>
  </div>
  <p class="text-gray-500">Detalle del grupo de formación</p>
</div>

<!-- Stats -->
<% registered = @coders.count %>
<% cap = @group.capacity.to_i %>
<% over = cap > 0 && registered > cap %>
<% at_cap = cap > 0 && registered == cap %>

<div class="grid grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
  <div class="bg-gray-900 rounded-2xl border border-gray-800 p-5">
    <p class="text-2xl font-bold text-violet-400"><%= registered %></p>
    <p class="text-sm text-gray-500">Coders Registrados</p>
  </div>
  <% if cap > 0 %>
    <div class="bg-gray-900 rounded-2xl border <%= over ? 'border-red-500/30' : at_cap ? 'border-amber-500/30' : 'border-gray-800' %> p-5">
      <div class="flex items-baseline gap-2">
        <p class="text-2xl font-bold <%= over ? 'text-red-400' : at_cap ? 'text-amber-400' : 'text-emerald-400' %>"><%= registered %><span class="text-base text-gray-600">/ <%= cap %></span></p>
      </div>
      <p class="text-sm text-gray-500">Cupos</p>
      <% if over %>
        <p class="text-xs text-red-400 mt-1">⚠ Sobran <%= registered - cap %> cupo(s)</p>
      <% elsif registered < cap %>
        <p class="text-xs text-emerald-400 mt-1">Faltan <%= cap - registered %> cupo(s)</p>
      <% else %>
        <p class="text-xs text-amber-400 mt-1">Cupo completo</p>
      <% end %>
    </div>
  <% end %>
  <div class="bg-gray-900 rounded-2xl border border-gray-800 p-5">
    <p class="text-2xl font-bold text-fuchsia-400"><%= @teams.count %></p>
    <p class="text-sm text-gray-500">Equipos</p>
  </div>
</div>

<!-- Coders Table -->
<div class="bg-gray-900 rounded-2xl border border-gray-800 overflow-hidden mb-8">
  <div class="px-6 py-4 border-b border-gray-800">
    <h2 class="text-lg font-semibold text-white">Coders del Grupo</h2>
  </div>
  <table class="w-full">
    <thead>
      <tr class="border-b border-gray-800">
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Nombre</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Email</th>
        <th class="text-center px-6 py-3 text-xs font-semibold text-gray-500 uppercase">ID Estudiante</th>
        <th class="text-center px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Estado</th>
        <th class="text-right px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Acciones</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800/50">
      <% @coders.each do |coder| %>
        <tr class="hover:bg-gray-800/30 transition-colors">
          <td class="px-6 py-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet-500/30 to-fuchsia-500/30 flex items-center justify-center text-xs font-bold text-violet-300">
                <%= coder.first_name[0] %><%= coder.last_name[0] %>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-200"><%= coder.full_name %></p>
                <% if coder.github_user.present? %>
                  <a href="https://github.com/<%= coder.github_user %>" target="_blank" class="text-xs text-violet-400 hover:text-violet-300 transition-colors"><%= coder.github_user %></a>
                <% end %>
              </div>
            </div>
          </td>
          <td class="px-6 py-3 text-sm text-gray-400"><%= coder.email %></td>
          <td class="px-6 py-3 text-sm text-gray-400 text-center"><%= coder.student_id %></td>
          <td class="px-6 py-3 text-center">
            <% if coder.team_member %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400">Asignado</span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-700 text-gray-400">Disponible</span>
            <% end %>
          </td>
          <td class="px-6 py-3 text-right">
            <%= link_to admin_coder_path(coder), data: { turbo_method: :delete, turbo_confirm: "¿Estás seguro de eliminar a #{coder.full_name}? Esta acción no se puede deshacer." }, class: "inline-flex items-center p-2 text-gray-500 hover:text-red-400 transition-colors rounded-lg hover:bg-red-500/10", title: "Eliminar Coder" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @coders.empty? %>
    <div class="text-center py-8 text-gray-500">
      <p class="text-sm">No hay coders en este grupo.</p>
    </div>
  <% end %>
</div>

<!-- Teams -->
<% if @teams.any? %>
  <div class="bg-gray-900 rounded-2xl border border-gray-800 p-6">
    <h2 class="text-lg font-semibold text-white mb-4">Equipos del Grupo</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% @teams.each do |team| %>
        <%= link_to admin_team_path(team), class: "block p-4 rounded-xl bg-gray-800/50 border border-gray-700/50 hover:border-violet-500/30 transition-all" do %>
          <p class="text-sm font-medium text-gray-200"><%= team.name %></p>
          <p class="text-xs text-gray-500 mt-1"><%= team.category_label %> · <%= team.coders.count %> miembros</p>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
