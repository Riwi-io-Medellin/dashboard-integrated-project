<% content_for(:title, "Iniciar Sesión — RIWI") %>

<!-- Logo Header -->
<div class="text-center mb-6">
  <%= image_tag "/riwi-logo.png", class: "mx-auto h-12 w-auto object-contain", alt: "RIWI Logo" %>
  <h2 class="mt-6 text-2xl font-heading font-bold text-white tracking-tight">Iniciar Sesión</h2>
</div>

<!-- Main Card -->
<div class="bg-gray-900 border border-gray-800 rounded-2xl py-8 px-4 shadow-xl sm:px-10">
  <% if alert %>
    <div class="p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-500 text-sm mb-6 flex items-start gap-3">
      <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <div class="flex-1 mt-0.5"><%= alert %></div>
    </div>
  <% end %>

  <% if notice %>
    <div class="p-4 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 text-sm mb-6 flex items-start gap-3">
      <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div class="flex-1 mt-0.5"><%= notice %></div>
    </div>
  <% end %>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), class: "space-y-5") do |f| %>
    <div class="space-y-2 mb-5">
      <%= f.label :email, "Correo electrónico", class: "block text-sm font-medium text-gray-300" %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"/></svg>
        </div>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true, class: "block w-full pl-10 pr-3 py-2.5 bg-gray-950 border border-gray-700/75 rounded-xl text-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500 transition-all placeholder-gray-600 shadow-sm", placeholder: "tu@email.com" %>
      </div>
    </div>

    <div class="space-y-2 mb-5">
      <div class="flex items-center justify-between">
        <%= f.label :password, "Contraseña", class: "block text-sm font-medium text-gray-300" %>
        <% if devise_mapping.recoverable? %>
          <%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name), class: "text-xs font-medium text-violet-400 hover:text-violet-300 transition-colors hover:underline underline-offset-2" %>
        <% end %>
      </div>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <%= f.password_field :password, autocomplete: "current-password", required: true, class: "block w-full pl-10 pr-3 py-2.5 bg-gray-950 border border-gray-700/75 rounded-xl text-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500 transition-all placeholder-gray-600 shadow-sm", placeholder: "••••••••" %>
      </div>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "h-4 w-4 bg-gray-950 border-gray-700 rounded text-violet-600 focus:ring-violet-500/50 focus:ring-offset-gray-900 transition-colors cursor-pointer" %>
          <%= f.label :remember_me, "Recordarme", class: "ml-2 block text-sm text-gray-400 cursor-pointer" %>
        </div>
      </div>
    <% end %>

    <div class="pt-2">
      <%= f.submit "Iniciar Sesión", class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-xl shadow-sm text-sm font-medium text-white bg-violet-600 hover:bg-violet-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-violet-500 transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-8 text-center text-sm">
    <p class="text-gray-400">
      ¿No tienes cuenta?
      <%= link_to "Regístrate ahora", new_registration_path(resource_name), class: "font-medium text-violet-400 hover:text-violet-300 transition-colors ml-1" %>
    </p>
  </div>
</div>

<p class="text-center text-xs text-gray-500 mt-8 font-medium">
  &copy; <%= Date.current.year %> RIWI — Proyectos Integrados
</p>
