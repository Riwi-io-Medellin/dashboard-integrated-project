<% content_for(:title, "Registrarse — RIWI") %>

<!-- Logo Header -->
<div class="text-center mb-6">
  <%= image_tag "/riwi-logo.png", class: "mx-auto h-12 w-auto object-contain", alt: "RIWI Logo" %>
  <h2 class="mt-6 text-2xl font-heading font-bold text-white tracking-tight">Crea tu cuenta</h2>
</div>

<!-- Main Card -->
<div class="bg-gray-900 border border-gray-800 rounded-2xl py-8 px-4 shadow-xl sm:px-10">
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), class: "space-y-5") do |f| %>
    <% if resource.errors.any? %>
      <div class="p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-500 text-sm mb-6">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <div class="flex-1">
            <h3 class="font-medium mb-1">Hubo un problema:</h3>
            <ul class="list-disc list-inside space-y-1 ml-1 text-red-400">
              <% resource.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Document Number Field -->
    <div class="space-y-2 mb-5">
      <%= f.label :document_number, "Número de Documento *", class: "block text-sm font-medium text-gray-300" %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/></svg>
        </div>
        <%= f.number_field :document_number, required: true, autofocus: true, inputmode: "numeric", pattern: "[0-9]*", class: "block w-full pl-10 pr-3 py-2.5 bg-gray-950 border border-gray-700/75 rounded-xl text-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500 transition-all placeholder-gray-600 shadow-sm", placeholder: "Ej. 1001234567" %>
      </div>
    </div>

    <!-- Email Field -->
    <div class="space-y-2 mb-5">
      <%= f.label :email, "Correo electrónico *", class: "block text-sm font-medium text-gray-300" %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"/></svg>
        </div>
        <%= f.email_field :email, autocomplete: "email", required: true, class: "block w-full pl-10 pr-3 py-2.5 bg-gray-950 border border-gray-700/75 rounded-xl text-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500 transition-all placeholder-gray-600 shadow-sm", placeholder: "tu@email.com" %>
      </div>
    </div>

    <!-- Password Field -->
    <div class="space-y-2 mb-5">
      <%= f.label :password, "Contraseña *", class: "block text-sm font-medium text-gray-300" %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <%= f.password_field :password, autocomplete: "new-password", required: true, class: "block w-full pl-10 pr-3 py-2.5 bg-gray-950 border border-gray-700/75 rounded-xl text-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500 transition-all placeholder-gray-600 shadow-sm", placeholder: "Mínimo 6 caracteres" %>
      </div>
    </div>

    <!-- Password Confirmation -->
    <div class="space-y-2 mb-6">
      <%= f.label :password_confirmation, "Confirmar contraseña *", class: "block text-sm font-medium text-gray-300" %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        </div>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true, class: "block w-full pl-10 pr-3 py-2.5 bg-gray-950 border border-gray-700/75 rounded-xl text-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500 transition-all placeholder-gray-600 shadow-sm", placeholder: "Repite tu contraseña" %>
      </div>
    </div>

    <div class="pt-2">
      <%= f.submit "Crear Cuenta", class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-xl shadow-sm text-sm font-medium text-white bg-violet-600 hover:bg-violet-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-violet-500 transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-8 text-center text-sm">
    <p class="text-gray-400">
      ¿Ya tienes cuenta?
      <%= link_to "Inicia sesión", new_user_session_path, class: "font-medium text-violet-400 hover:text-violet-300 transition-colors ml-1" %>
    </p>
  </div>
</div>

<p class="text-center text-xs text-gray-500 mt-8 font-medium">
  &copy; <%= Date.current.year %> RIWI — Proyectos integradores
</p>
